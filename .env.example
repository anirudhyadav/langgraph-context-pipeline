# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0

# Cheap model for history summarisation — runs on every turn
SUMMARY_MODEL=gpt-4o-mini

# ── MongoDB Atlas Vector Search ───────────────────────────────────────────────
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_NAMESPACE=mydb.documents

# ── Pipeline Configuration ────────────────────────────────────────────────────
# Total token budget for the assembled context window
TOKEN_BUDGET=10000

# Number of recent conversation turns to keep verbatim before summarising
MAX_HISTORY_TURNS=6

# Max characters per tool output before truncation
MAX_TOOL_OUTPUT_CHARS=900

# Minimum relevance score for retrieved documents (0.0 – 1.0)
RETRIEVAL_THRESHOLD=0.75

# Number of candidate documents to retrieve before score filtering
RETRIEVAL_TOP_K=8

# ── System Prompt (optional — pipeline has a sensible default) ────────────────
# SYSTEM_PROMPT=You are a precise AI assistant. Answer only from the provided context.
